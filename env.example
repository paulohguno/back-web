# ================================================
# VARIÁVEIS DE AMBIENTE — BACKEND (Render)
# Copie este arquivo para .env e preencha os valores
# ================================================

# URL completa do banco PostgreSQL do Render
# Exemplo: postgres://usuario:senha@hostname:5432/nomedb
DATABASE_URL=postgres://SEU_USUARIO:SUA_SENHA@SEU_HOST:5432/SEU_BANCO

# Habilita SSL para conexão com banco do Render (obrigatório)
DB_SSL=true

# Porta do servidor (o Render define automaticamente via PORT)
PORT=3333

# Chave secreta para JWT — troque por algo longo e aleatório!
JWT_SECRET=TROQUE_POR_UMA_CHAVE_LONGA_E_SECRETA_AQUI

# URL do frontend no Vercel (para configurar CORS)
FRONTEND_URL=https://SEU-PROJETO.vercel.app
